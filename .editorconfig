
root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

[*.rs]
indent_size = 4
max_line_length = 100

[*.{toml,yaml,yml,json,md}]
indent_style = space
indent_size = 2

[{node_modules,target,*.lock,*.min.js,*.map}]
end_of_line = unset
trim_trailing_whitespace = false
insert_final_newline = false
indent_style = unset